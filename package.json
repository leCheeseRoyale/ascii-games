{
  "name": "ascii-game-engine",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun run scripts/dev.ts",
    "dev:fast": "bunx vite",
    "build": "bunx vite build",
    "preview": "bunx vite preview",
    "check": "bunx tsc --noEmit",
    "check:bounds": "bun run scripts/check-boundaries.ts",
    "check:all": "bun run check && bun run check:bounds && bun run lint",
    "lint": "bunx biome check .",
    "lint:fix": "bunx biome check --fix .",
    "knip": "bunx knip",
    "gen:api": "bun run scripts/gen-api.ts",
    "new:scene": "bun run scripts/new-scene.ts",
    "new:system": "bun run scripts/new-system.ts",
    "new:entity": "bun run scripts/new-entity.ts",
    "init:game": "bun run scripts/init-game.ts",
    "list:games": "bun run scripts/list-games.ts",
    "export": "bun run scripts/export.ts",
    "ai:sprite": "bun run scripts/ai-sprite.ts",
    "ai:mechanic": "bun run scripts/ai-mechanic.ts",
    "ai:juice": "bun run scripts/ai-juice.ts",
    "ai:game": "bun run scripts/ai-game.ts",
    "ai:scene": "bun run scripts/ai-scene.ts",
    "build:pkg": "cd packages/ascii-game-engine && bunx tsup",
    "test": "bun test",
    "bench": "bun run engine/__bench__/run.ts"
  },
  "dependencies": {
    "@chenglou/pretext": "^0.0.4",
    "@zzfx-studio/zzfxm": "^0.1.2",
    "lz-string": "^1.5.0",
    "miniplex": "^2.0.0",
    "mitt": "^3.0.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "simplex-noise": "^4.0.3",
    "zod": "^3.24.0",
    "zustand": "^5.0.12",
    "zzfx": "^1.3.2"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "@biomejs/biome": "^2.4.10",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.5.2",
    "bun-types": "^1.3.12",
    "knip": "^6.3.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vite": "^6.3.1"
  }
}

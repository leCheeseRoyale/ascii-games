{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "rootDir": "../..",
    "outDir": "./dist",
    "declaration": true,
    "declarationDir": "./dist",
    "noEmit": false,
    "skipLibCheck": true,
    "paths": {
      "@shared/*": ["../../shared/*"],
      "@shared": ["../../shared/index.ts"],
      "@engine/*": ["../../engine/*"],
      "@engine": ["../../engine/index.ts"]
    }
  },
  "include": [
    "../../engine/**/*.ts",
    "../../shared/**/*.ts",
    "../../ui/store.ts",
    "vendor.d.ts"
  ],
  "exclude": [
    "../../engine/__tests__/**",
    "../../engine/__bench__/**"
  ]
}
